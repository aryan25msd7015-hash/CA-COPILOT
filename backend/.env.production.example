DATABASE_URL=postgresql://ca_app:${DB_PASSWORD}@${DB_HOST}:5432/ca_platform
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:6379/0
SECRET_KEY=replace-with-64-byte-random-secret
S3_BUCKET=replace-with-production-bucket
AWS_REGION=ap-south-1
FRONTEND_URL=https://app.example.com
ENV=production
SQL_ECHO=false
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_PREFIX=ca-copilot:rate-limit
TRUSTED_HOSTS=app.example.com,api.example.com
AZURE_DOC_ENDPOINT=
AZURE_DOC_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=replace-with-provider-verify-token
EMAIL_PROVIDER=smtp
EMAIL_FROM=CA Copilot <no-reply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
PAYMENT_LINK_EXPIRE_DAYS=30
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
METRICS_ENABLED=true
METRICS_BEARER_TOKEN=replace-with-prometheus-scrape-token
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
